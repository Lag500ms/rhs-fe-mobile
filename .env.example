# API base URL (bắt buộc kết thúc bằng /api)
# - iOS Simulator: http://localhost:5112/api
# - Android emulator: http://10.0.2.2:5112/api
# - Physical device: http://<LAN-IP>:5112/api
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:5112/api

# Mapbox public token (pk.*) — hạn chế URL/domain trên Mapbox dashboard
# Không đặt secret key (sk.*) vào biến EXPO_PUBLIC_*
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here
